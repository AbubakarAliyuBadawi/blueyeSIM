<?xml version="1.0" encoding="UTF-8"?>
<!-- Full autonomous mission: undocking → inspection → docking, with takeover guard.

     Mission states published to /mission_state:
       1 = UNDOCKING
       2 = TRANSIT          (BT publishes on LaunchMission start)
       3 = INSPECTION       (mission.py publishes when first waypoint reached)
       4 = DOCKING
       5 = EMERGENCY ABORT
       6 = EMERGENCY DOCKING
       7 = TAKEOVER REQUESTED

     Normal flow:
       PublishState(1) → LaunchUndocking → ActivateAutoModes
       PublishState(2) → LaunchMission
       PublishState(3) → LaunchDocking → charging confirmed → SUCCESS

     Takeover triggered (urgency >= threshold):
       LaunchMissionProcedure::onHalted() publishes "pause" → drone holds depth.
       LaunchDockingProcedure::onHalted()  stops docking nodes cleanly.

       ACCEPT — EnableJoystick (sets g_mission_paused=true) → WaitForHandback
                → AlwaysFail → tree fails with g_mission_paused=true
                → main.cpp resets tree → LaunchUndocking skips (already_done_=true)
                → LaunchMission resumes paused script from where it left off.
       REJECT — emergency surface waypoint → LaunchDocking (operator manually docks). -->

<root BTCPP_format="4"
      main_tree_to_execute="FullMission">
  <BehaviorTree ID="FullMission">

    <Fallback name="mission_with_takeover_guard">

      <!-- ── NORMAL MISSION (interrupted if urgency >= threshold) ─────────── -->
      <ReactiveSequence name="guarded_mission">
        <CheckTakeoverRequest/>

        <Sequence name="mission">

          <!-- Phase 1: Undocking (skipped on resume — already_done_=true) -->
          <PublishState state="1"/>
          <LaunchUndockingProcedure name="undocking_procedure"
                                    script_path="/home/badawi/Desktop/auto-pilot/src/blueye_real_bt/bash_scripts/launch_undocking_real.sh"
                                    drone_ip="192.168.1.101"
                                    reverse_duration="10"
                                    reverse_power="0.8"/>

          <!-- Stabilise before starting inspection -->
          <ActivateAutoModes name="post_undocking_stabilization"
                             depth_hold="true"
                             heading_hold="true"
                             hold_duration="5"/>

          <!-- Phase 2: Transit / Inspection -->
          <PublishState state="2"/>
          <LaunchMissionProcedure name="pipeline_inspection_mission"
                                  script_path="/home/badawi/Desktop/auto-pilot/src/blueye_real_bt/bash_scripts/launch_mission.sh"
                                  drone_ip="192.168.1.101"
                                  max_retries="10"/>

          <!-- Phase 4: Docking -->
          <PublishState state="4"/>
          <LaunchDockingProcedure name="launch_integrated_docking"/>

        </Sequence>
      </ReactiveSequence>

      <!-- ── TAKEOVER HANDLER (runs when CheckTakeoverRequest fails) ──────── -->
      <!-- Drone is already holding depth: LaunchMissionProcedure::onHalted()  -->
      <!-- published "pause" before this sequence started.                     -->
      <Sequence name="takeover_handler">

        <PublishState state="7"/>

        <!-- Wait for operator decision. Always returns SUCCESS.
             Writes result to blackboard key "human_decision" (true=accept). -->
        <WaitForHumanDecision decision="{human_decision}"/>

        <Fallback name="decision_branch">

          <!-- REJECT: operator aborts mission — go to surface, then dock.
               takeover_handler succeeds → outer Fallback succeeds → tree done. -->
          <Sequence name="reject_path">
            <CheckBlackboardBool key="human_decision" expected_value="false"/>
            <PublishState state="5"/>
            <GoToWaypoint name="emergency_surface_waypoint"
                          waypoint_lat="63.4406996"
                          waypoint_lon="10.3489307"
                          depth="1.5"
                          drone_ip="192.168.1.101"/>
            <PublishState state="6"/>
            <LaunchDockingProcedure name="emergency_docking"/>
          </Sequence>

          <!-- ACCEPT: operator takes joystick → flies → hands back → mission resumes.
               EnableJoystick sets g_mission_paused=true.
               AlwaysFail causes tree to complete with FAILURE + g_mission_paused=true.
               main.cpp resets tree: LaunchUndocking skips, LaunchMission resumes. -->
          <Sequence name="accept_path">
            <EnableJoystick/>
            <WaitForHandback/>
            <AlwaysFail/>
          </Sequence>

        </Fallback>
      </Sequence>

    </Fallback>
  </BehaviorTree>

  <!-- Node model (Groot2 metadata) -->
  <TreeNodesModel>
    <Action ID="ActivateAutoModes">
      <input_port name="depth_hold"    default="true" type="Bool">Enable depth hold</input_port>
      <input_port name="heading_hold"  default="true" type="Bool">Enable heading hold</input_port>
      <input_port name="hold_duration" default="10"   type="Int">Hold duration in seconds</input_port>
    </Action>
    <Condition ID="CheckBlackboardBool">
      <input_port name="key"            type="String">Blackboard key to read</input_port>
      <input_port name="expected_value" default="true"  type="Bool">Value to compare against</input_port>
      <input_port name="invert_result"  default="false" type="Bool">Invert the comparison result</input_port>
    </Condition>
    <Condition ID="CheckTakeoverRequest"/>
    <Action ID="EnableJoystick"/>
    <Action ID="GoToWaypoint">
      <input_port name="waypoint_lat" type="Double">Target latitude</input_port>
      <input_port name="waypoint_lon" type="Double">Target longitude</input_port>
      <input_port name="depth"        default="1.0"           type="Double">Target depth in metres</input_port>
      <input_port name="drone_ip"     default="192.168.1.101" type="String">Drone IP</input_port>
    </Action>
    <Action ID="LaunchDockingProcedure" editable="true"/>
    <Action ID="LaunchMissionProcedure">
      <input_port name="script_path" type="String">Path to mission script</input_port>
      <input_port name="drone_ip"    type="String">Drone IP</input_port>
      <input_port name="max_retries" default="5" type="Int">Max retry attempts</input_port>
    </Action>
    <Action ID="LaunchUndockingProcedure">
      <input_port name="script_path"      default="/home/badawi/Desktop/auto-pilot/src/blueye_real_bt/bash_scripts/launch_undocking_real.sh" type="String">Path to undocking script</input_port>
      <input_port name="drone_ip"         default="192.168.1.101" type="String">Drone IP</input_port>
      <input_port name="reverse_duration" default="10"  type="Int">Reverse duration in seconds</input_port>
      <input_port name="reverse_power"    default="0.8" type="Float">Reverse power (0.1–1.0)</input_port>
    </Action>
    <Action ID="PublishState">
      <input_port name="state" type="Int">Mission state integer to publish</input_port>
    </Action>
    <Action ID="WaitForHandback"/>
    <Action ID="WaitForHumanDecision">
      <output_port name="decision" type="Bool">true = accepted, false = rejected</output_port>
    </Action>
  </TreeNodesModel>

</root>
